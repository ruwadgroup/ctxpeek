{
  "name": "ctxpeek",
  "private": true,
  "version": "0.0.0",
  "description": "ctxpeek (pronounced Context Peek) is a local-first MCP server for fresh, version-pinned repo docs.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/ruwadgroup/ctxpeek#readme",
  "bugs": {
    "url": "https://github.com/ruwadgroup/ctxpeek/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ruwadgroup/ctxpeek.git"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "dev": "pnpm --filter ctxpeek run dev",
    "test": "pnpm build && pnpm -r --filter './packages/*' run test",
    "test:ci": "pnpm build && pnpm -r --filter './packages/*' run test:ci",
    "typecheck": "pnpm build && pnpm -r --filter './packages/*' run typecheck",
    "lint": "pnpm run lint:js && pnpm run lint:py && pnpm run lint:md",
    "lint:js": "biome lint .",
    "lint:py": "ruff check .",
    "lint:md": "prettier --check \"**/*.md\"",
    "format": "pnpm run format:js && pnpm run format:py && pnpm run format:md",
    "format:js": "biome format --write .",
    "format:py": "ruff format .",
    "format:md": "prettier --write \"**/*.md\"",
    "format:check": "pnpm run format:check:js && pnpm run format:check:py && pnpm run format:check:md",
    "format:check:js": "biome format .",
    "format:check:py": "ruff format --check .",
    "format:check:md": "prettier --check \"**/*.md\"",
    "check": "biome check --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
